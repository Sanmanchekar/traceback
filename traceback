#!/usr/bin/env node

/**
 * Traceback CLI for direct command usage in Claude Code
 * Usage: /traceback <command> <args>
 */

const path = require('path');
const { Traceback } = require('./dist/index');

// Initialize Traceback
const traceback = new Traceback();
let lastAnalysis = null;

// Parse command line arguments
const args = process.argv.slice(2);

if (args.length === 0) {
  console.log('Traceback - Root Cause Analysis Tool');
  console.log('\nCommands:');
  console.log('  analyze <issue>     - Analyze an issue');
  console.log('  solutions           - Get solutions for last analysis');
  console.log('  recommend           - Get recommended solution');
  console.log('  implement <id>      - Implement a solution');
  console.log('  status              - Show current status');
  process.exit(0);
}

const command = args[0];
const commandArgs = args.slice(1).join(' ');

async function main() {
  try {
    switch (command) {
      case 'analyze':
        if (!commandArgs) {
          console.error('Error: Issue description required');
          console.log('Usage: /traceback analyze "your issue description"');
          process.exit(1);
        }
        
        console.log(`🔍 Analyzing: ${commandArgs}`);
        const result = await traceback.analyze(commandArgs);
        lastAnalysis = result;
        
        console.log(`\n✅ Analysis complete!`);
        console.log(`Found ${result.rootCauses.length} root causes:`);
        result.rootCauses.forEach((cause, i) => {
          console.log(`  ${i + 1}. ${cause.description} (${(cause.confidence * 100).toFixed(0)}% confidence)`);
        });
        
        console.log(`\n💡 Generated ${result.solutions.length} solutions`);
        if (result.recommendation.primarySolution) {
          console.log(`\n⭐ Recommended: ${result.recommendation.primarySolution.title}`);
          console.log(`   Score: ${result.recommendation.primarySolution.ratings.overall}/10`);
        }
        break;
        
      case 'solutions':
        const solutions = await traceback.solutions({ count: 5 });
        console.log('\n📊 Solutions:');
        solutions.forEach((sol, i) => {
          const rec = sol.recommended ? ' ⭐' : '';
          console.log(`\n${i + 1}. ${sol.title}${rec}`);
          console.log(`   Overall Score: ${sol.ratings.overall}/10`);
          console.log(`   Approach: ${sol.approach}`);
        });
        break;
        
      case 'recommend':
        const recommended = await traceback.recommend();
        if (recommended) {
          console.log('\n⭐ Recommended Solution:');
          console.log(`   ${recommended.title}`);
          console.log(`   Score: ${recommended.ratings.overall}/10`);
          console.log(`   ${recommended.description}`);
        } else {
          console.log('No recommendation available. Run analyze first.');
        }
        break;
        
      case 'implement':
        const solutionId = args[1];
        if (!solutionId) {
          console.error('Error: Solution ID required');
          process.exit(1);
        }
        
        const impl = await traceback.implement(solutionId, { dryRun: true });
        console.log(`\n🔧 Implementation Plan for: ${impl.solution.title}`);
        impl.implementation.forEach((step, i) => {
          console.log(`   ${i + 1}. ${step.step}`);
        });
        break;
        
      case 'status':
        const status = traceback.status();
        console.log('\n📊 Status:');
        console.log(JSON.stringify(status, null, 2));
        break;
        
      default:
        console.error(`Unknown command: ${command}`);
        console.log('Run /traceback for help');
        process.exit(1);
    }
  } catch (error) {
    console.error('Error:', error.message);
    process.exit(1);
  }
}

main();